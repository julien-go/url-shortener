PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=
PUBLIC_BASE_URL=http://localhost:4000
APP_NAME=Fliro
APP_DASHBOARD_URL=http://localhost:5173
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/url_shortener?sslmode=disable
DBMATE_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/url_shortener?sslmode=disable
JWT_SECRET=change-me
NODE_ENV=dev
TRUST_PROXY=1
JSON_BODY_LIMIT=16kb
RL_REDIRECT_WINDOW_MS=60000
RL_REDIRECT_MAX=60
RL_CREATE_WINDOW_MS=60000
RL_CREATE_MAX=10
RL_AUTH_WINDOW_MS=60000
RL_AUTH_MAX=5
RL_AUTH_BLOCK_BASE_SECONDS=30

# Cookie auth
COOKIE_NAME=auth_token
COOKIE_SAMESITE=Lax
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_SECURE=false
COOKIE_MAX_AGE_SECONDS=900

# Security headers
ENABLE_CSP=true

# Metrics
METRICS_ENABLED=false
METRICS_API_KEY=replace-with-internal-secret