{
  "name": "backend",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "db:migrate": "dotenv -e ../../.env -- cross-env DBMATE_MIGRATIONS_DIR=../../migrations dbmate up",
    "db:status": "dotenv -e ../../.env -- cross-env DBMATE_MIGRATIONS_DIR=../../migrations dbmate status",
    "db:rollback": "dotenv -e ../../.env -- cross-env DBMATE_MIGRATIONS_DIR=../../migrations dbmate down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@apollo/server": "^5.3.0",
    "@as-integrations/express5": "^1.1.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.9",
    "@types/pg": "^8.16.0",
    "cross-env": "^10.1.0",
    "dbmate": "^2.30.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  }
}
