{
  "name": "backend",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Fliro backend — GraphQL API (Apollo Server) + short-link redirection, Express 5 + PostgreSQL.",
  "author": "Julien Godard",
  "license": "ISC",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "db:migrate": "dotenv -e ../../.env -- cross-env DBMATE_MIGRATIONS_DIR=./migrations dbmate up",
    "db:status": "dotenv -e ../../.env -- cross-env DBMATE_MIGRATIONS_DIR=./migrations dbmate status",
    "db:rollback": "dotenv -e ../../.env -- cross-env DBMATE_MIGRATIONS_DIR=./migrations dbmate down",
    "db:migrate:prod": "cross-env DBMATE_MIGRATIONS_DIR=./migrations dbmate up",
    "db:status:prod": "cross-env DBMATE_MIGRATIONS_DIR=./migrations dbmate status",
    "db:rollback:prod": "cross-env DBMATE_MIGRATIONS_DIR=./migrations dbmate down"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "dbmate": "^2.34.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
